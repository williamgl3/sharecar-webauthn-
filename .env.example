# VITE_API_URL — leave empty so it defaults to /api (works with Vite proxy + Netlify redirects)
# For local dev, Vite proxy in vite.config.js forwards /api -> http://localhost:4000
# VITE_API_URL=http://localhost:4000

# Stellar configuration (uses TESTNET by default)
# Change to PUBLIC for mainnet (requires real XLM)
VITE_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
VITE_STELLAR_NETWORK=TESTNET

# Server-side Stellar — set PLATFORM_PUBLIC_KEY in Netlify env vars to enable XLM deduction on reserve
# PLATFORM_PUBLIC_KEY=your_platform_public_key_here
